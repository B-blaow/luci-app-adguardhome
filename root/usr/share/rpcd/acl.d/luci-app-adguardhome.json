{
	"luci-app-adguardhome": {
		"description": "Grant access to luci-app-adguardhome runtime helpers",
		"read": {
			"uci": [ "AdGuardHome" ],
			"file": {
				"/usr/share/AdGuardHome/links.txt": [ "read" ],
				"/tmp/AdGuardHome_update.log": [ "read" ],
				"/tmp/AdGuardHometmpconfig.yaml": [ "read" ],
				"/etc/AdGuardHome.yaml": [ "read" ]
			}
		},
		"write": {
			"uci": [ "AdGuardHome", "dhcp", "firewall" ],
			"file": {
				"/usr/libexec/AdGuardHome/luci-helper.sh": [ "exec" ],
				"/etc/init.d/AdGuardHome": [ "exec" ],
				"/usr/share/AdGuardHome/gfw2adg.sh": [ "exec" ],
				"/bin/sh": [ "exec" ],
				"/usr/share/AdGuardHome/links.txt": [ "write" ],
				"/tmp/AdGuardHometmpconfig.yaml": [ "write" ],
				"/etc/AdGuardHome.yaml": [ "write" ]
			}
		}
	}
}

{
  "luci-app-adguardhome": {
    "description": "Grant access to LuCI app AdGuardHome",
    "read": {
      "uci": [ "AdGuardHome" ],
      "file": [
        "/etc/AdGuardHome.yaml",
        "/usr/share/AdGuardHome/*",
        "/var/log/AdGuardHome.log",
        "/tmp/AdH_update.log",
        "/tmp/AdGuardHome_update.log",
        "/tmp/AdGuardHome.log"
      ],
      "ubus": {
        "service": [ "list" ],
        "luci.adguardhome": [ "check_version", "get_links" ]
      }
    },
    "write": {
      "uci": [ "AdGuardHome" ],
      "file": [
        "/etc/AdGuardHome.yaml",
        "/usr/share/AdGuardHome/links.txt",
        "/tmp/AdH_update.log",
        "/tmp/AdGuardHome_update.log",
        "/tmp/AdGuardHome.log"
      ],
      "ubus": {
        "luci.adguardhome": [ "update_core", "set_links" ]
      }
    }
  }
}
